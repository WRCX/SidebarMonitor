<?xml version="1.0" encoding="utf-8"?>
<!--
  SidebarMonitor MSI (WiX v6). Installs the three apps to Program Files, registers the elevated
  helper as a logon scheduled task, sets the UI to autostart under the user's Run key, and adds a
  Start-menu shortcut. The install path is fixed so the launcher and task XML can hardcode it.
  Build with installer/build.ps1 (which stages the self-contained publish + generated files).
-->
<?ifndef Flavor ?><?define Flavor = "full" ?><?endif?>
<!-- Where the finish page's "see what's new" goes. build.ps1 passes the exact release tag; the
     fallback tracks whatever is newest, which is right for a build cut outside it. -->
<?ifndef ReleaseUrl ?><?define ReleaseUrl = "https://github.com/WRCX/SidebarMonitor/releases/latest" ?><?endif?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="SidebarMonitor"
           Manufacturer="WRCX"
           Version="$(Version)"
           UpgradeCode="5B2D9E14-7C3A-4F6B-9A21-8E4D2C1F0A73"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <!-- AllowSameVersionUpgrades lets the user switch between the full and lite installers (same
         version, different bundling) without uninstalling first. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of SidebarMonitor is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Task Manager / Add-Remove Programs identity. -->
    <Icon Id="AppIcon.ico" SourceFile="$(ProjectRoot)\assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/WRCX/SidebarMonitor" />

    <!-- We stop the stack ourselves (StopStack below), deterministically and as SYSTEM, so the
         Restart Manager must not race us: left on, it detects our locked files at InstallValidate,
         shows the "close these applications" dialog and force-kills processes in an arbitrary order
         — which the UI defeats, because it RELAUNCHES a missing agent within ~2 s (the crashed-agent
         recovery). RM kills the agent, the UI revives it, the file is in use again: that is the
         3-4-retry loop users saw. Off + our own ordered stop = one clean pass, no prompts. -->
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />

    <!-- Fixed install location: no directory picker, so the launcher/task paths stay valid. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SidebarMonitor" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />

    <Feature Id="Main" Title="SidebarMonitor" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AutostartAndShortcut" />
      <ComponentRef Id="InstallInfo" />
    </Feature>

    <!-- Install metadata the in-app updater reads (per-machine, so it survives a %LOCALAPPDATA% wipe
         and is written elevated by the MSI, read unelevated by the UI): where we installed, which
         version, and which flavour (full/lite) so the updater downloads the matching MSI. -->
    <Component Id="InstallInfo" Directory="INSTALLFOLDER" Guid="C4E1B7A0-9D62-4F38-8B15-6A2E7C0D9F41">
      <RegistryValue Root="HKLM" Key="Software\SidebarMonitor" Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
      <RegistryValue Root="HKLM" Key="Software\SidebarMonitor" Name="Version" Type="string" Value="$(Version)" />
      <RegistryValue Root="HKLM" Key="Software\SidebarMonitor" Name="Flavor" Type="string" Value="$(Flavor)" />
    </Component>

    <!-- Autostart (UI under the all-users Run key) + Start-menu shortcut. HKLM, NOT HKCU: this is a
         per-machine MSI, installed by the msiexec SYSTEM service, so an HKCU Run value lands in SYSTEM's
         profile instead of the user's and the UI never autostarts. HKLM Run is written correctly by
         SYSTEM and starts the UI for every user at logon (each reads its own %LOCALAPPDATA% config). -->
    <Component Id="AutostartAndShortcut" Directory="ProgramMenuFolder" Guid="4B9D2E10-7C34-4A6E-9F81-3D5C8B2A1E90">
      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="SidebarMonitor"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]SidebarMonitor.UI.exe&quot;"
                     KeyPath="yes" />
      <Shortcut Id="StartMenuShortcut"
                Name="SidebarMonitor"
                Target="[INSTALLFOLDER]SidebarMonitor.UI.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
    </Component>

    <!-- The elevated helper runs from a logon scheduled task (Highest run level = no UAC prompt),
         created/removed with schtasks against the staged XML. Deferred + non-impersonated so it runs
         with the privileges to register a Highest-runlevel task. Paths are the fixed install dir. -->
    <!-- Stop the whole stack BEFORE InstallValidate, or Windows Installer finds our binaries locked
         and starts its own close-and-retry dance. This has to be an IMMEDIATE action (deferred ones
         cannot run this early), i.e. unelevated — which is exactly why the helper honours a
         cooperative stop file: nothing unelevated can terminate an elevated, windowless process.
         Order is not incidental:
           1. /End the helper task first, so its logon/session triggers cannot relaunch it mid-install.
           2. Ask the helper to quit (it consumes the file within ~1 s and stops its ETW session cleanly).
           3. Kill the UI BEFORE the agent — the reverse lets the UI resurrect the agent (crashed-agent
              recovery, ~2 s backoff) right as we delete its exe. THAT was the 3-4-retry loop.
           4. Then the agent. Pings are a console-safe sleep (`timeout` needs a console).

         Run through WixQuietExec rather than as a plain exe action. An immediate, impersonated action
         runs in the USER's session, so a plain cmd.exe hands them a console window flashing schtasks
         and taskkill chatter — in whatever language their Windows speaks, since those messages are
         Windows', not ours. (The deferred actions below don't need this: they run as SYSTEM in session
         0, where nothing is visible.) QuietExec runs it windowless and folds stdout/stderr into the MSI
         log instead, so the detail is still there for `msiexec /i … /l*v install.log`. -->
    <SetProperty Action="SetStopStackCmd" Id="WixQuietExecCmdLine"
                 Value="&quot;cmd.exe&quot; /c schtasks.exe /End /TN &quot;SidebarMonitor Helper&quot; &amp; mkdir &quot;%ProgramData%\SidebarMonitor&quot; 2>nul &amp; echo stop > &quot;%ProgramData%\SidebarMonitor\helper-stop&quot; &amp; taskkill /F /IM SidebarMonitor.UI.exe &amp; ping -n 3 127.0.0.1 >nul &amp; taskkill /F /IM SidebarMonitor.Agent.exe &amp; ping -n 4 127.0.0.1 >nul"
                 Before="StopStack" Sequence="execute" />
    <CustomAction Id="StopStack"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="immediate" Impersonate="yes" Return="ignore" />

    <!-- Every action below is a deferred exe. Windows Installer runs those through a custom action
         server, and whether that server's child gets a visible console is not something to assume:
         it was assumed to be invisible (SYSTEM, session 0), and users saw the windows anyway. So they
         all go through WixQuietExec too — windowless by construction, with stdout/stderr folded into
         the MSI log, which is strictly better than a console nobody reads. For a DEFERRED action,
         QuietExec reads its command from CustomActionData, which is why each SetProperty below is
         named after its action rather than WixQuietExecCmdLine. -->

    <!-- Backstop, as SYSTEM: whatever survived the cooperative stop (a helper wedged mid-window, or
         another logged-in user's UI/agent — `taskkill /IM` as SYSTEM reaches every session, which an
         impersonated action cannot) is force-killed before a single file is touched. -->
    <SetProperty Action="SetForceStopStackCmd" Id="ForceStopStack"
                 Value="&quot;cmd.exe&quot; /c taskkill /F /IM SidebarMonitor.UI.exe &amp; taskkill /F /IM SidebarMonitor.Agent.exe &amp; taskkill /F /IM SidebarMonitor.Etw.exe &amp; ping -n 2 127.0.0.1 >nul"
                 Before="ForceStopStack" Sequence="execute" />
    <CustomAction Id="ForceStopStack"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <SetProperty Action="SetCreateHelperTaskCmd" Id="CreateHelperTask"
                 Value="&quot;schtasks.exe&quot; /Create /TN &quot;SidebarMonitor Helper&quot; /XML &quot;C:\Program Files\SidebarMonitor\helper-task.xml&quot; /F"
                 Before="CreateHelperTask" Sequence="execute" />
    <CustomAction Id="CreateHelperTask"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- The UI task: hands the sidebar back to every OTHER user whose UI this upgrade had to kill,
         the moment they return to their session (the Run key only fires at logon). Redundant firings
         are free — the UI is single-instance per session. -->
    <SetProperty Action="SetCreateUiTaskCmd" Id="CreateUiTask"
                 Value="&quot;schtasks.exe&quot; /Create /TN &quot;SidebarMonitor UI&quot; /XML &quot;C:\Program Files\SidebarMonitor\ui-task.xml&quot; /F"
                 Before="CreateUiTask" Sequence="execute" />
    <CustomAction Id="CreateUiTask"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <SetProperty Action="SetDeleteUiTaskCmd" Id="DeleteUiTask"
                 Value="&quot;schtasks.exe&quot; /Delete /TN &quot;SidebarMonitor UI&quot; /F"
                 Before="DeleteUiTask" Sequence="execute" />
    <CustomAction Id="DeleteUiTask"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <!-- Best effort, and a race we are happy to lose. This runs inside the install transaction, so the
         helper it starts usually sees Global\_MSIExecute still held and steps aside on purpose (it must:
         a live helper maps its exe out of the folder we are still writing, which is what "files in use"
         and a failed rollback are made of). If the scheduler happens to start it after InstallFinalize,
         it stays up and the sidebar has sensors instantly. Either way the task's one-minute watchdog
         has it running within a minute of the install finishing — that is the guarantee; this is the
         shortcut. -->
    <SetProperty Action="SetRunHelperNowCmd" Id="RunHelperNow"
                 Value="&quot;schtasks.exe&quot; /Run /TN &quot;SidebarMonitor Helper&quot;"
                 Before="RunHelperNow" Sequence="execute" />
    <CustomAction Id="RunHelperNow"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <SetProperty Action="SetDeleteHelperTaskCmd" Id="DeleteHelperTask"
                 Value="&quot;schtasks.exe&quot; /Delete /TN &quot;SidebarMonitor Helper&quot; /F"
                 Before="DeleteHelperTask" Sequence="execute" />
    <CustomAction Id="DeleteHelperTask"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Purge any pre-1.4.4 PER-USER install (install.ps1 published framework-dependent into
         %LOCALAPPDATA%\SidebarMonitor\app and pointed HKCU Run at it). The MSI's own UI is
         self-contained under Program Files, but that stale copy still autostarts and dies with
         "You must install or update .NET" on a machine without the runtime. Impersonated (NOT
         deferred/no-impersonate) precisely so HKCU and %LOCALAPPDATA% resolve to the INSTALLING
         user's profile rather than SYSTEM's. Other users' stale copies are cleaned by the UI's
         own first run; this covers the common single-installer case. -->
    <SetProperty Action="SetPurgeLegacyCmd" Id="WixQuietExecCmdLine"
                 Value="&quot;cmd.exe&quot; /c reg delete &quot;HKCU\Software\Microsoft\Windows\CurrentVersion\Run&quot; /v SidebarMonitor /f &amp; rmdir /s /q &quot;%LOCALAPPDATA%\SidebarMonitor\app&quot;"
                 Before="PurgeLegacyPerUserInstall" Sequence="execute" />
    <CustomAction Id="PurgeLegacyPerUserInstall"
                  DllEntry="WixQuietExec" BinaryRef="Wix4UtilCA_X64"
                  Execute="immediate" Impersonate="yes" Return="ignore" />

    <InstallExecuteSequence>
      <!-- On BOTH install and uninstall: nothing may hold a binary when files move. -->
      <Custom Action="StopStack" Before="InstallValidate" />
      <Custom Action="ForceStopStack" Before="InstallFiles" />
      <Custom Action="PurgeLegacyPerUserInstall" Before="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="CreateHelperTask" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="CreateUiTask" After="CreateHelperTask" Condition="NOT REMOVE" />
      <Custom Action="RunHelperNow" After="CreateUiTask" Condition="NOT REMOVE" />
      <Custom Action="DeleteHelperTask" Before="RemoveFiles" Condition="REMOVE" />
      <Custom Action="DeleteUiTask" Before="RemoveFiles" Condition="REMOVE" />
    </InstallExecuteSequence>

    <!-- ── Finish page ────────────────────────────────────────────────────────────────────────────
         Two checkboxes, the way installers normally end: start the app, and see what changed.
         Both default to checked.

         This is WixUI_Minimal rebuilt by hand (same dialog list, same license page) for ONE reason:
         WixUI_Minimal's ExitDialog carries a single optional checkbox
         (WIXUI_EXITDIALOGOPTIONALCHECKBOX), and a dialog from the UI wixlib cannot be extended — a
         second <Control> on it fails to build with "Duplicate Dialog ExitDialog". Two checkboxes
         means authoring the exit dialog ourselves, which means not referencing theirs.

         Nothing here runs during a silent install (/qn): the InstallUISequence is skipped entirely,
         so an unattended machine never sees a changelog or a dialog — the automatic updater's path.
         The stack still comes up on its own there: RunHelperNow starts the helper, the Run key and
         the UI task start the sidebar. -->
    <!-- Starting the app is what you almost always want, so it is ticked. The changelog is not: it is
         a detour to a browser, and most installs just want the sidebar back.
         SBM_CHANGELOG is deliberately NOT declared here. A checkbox is ticked when its property has
         any non-empty value, so Value="0" would tick it — "unticked" means the property does not
         exist. Ticking the box sets it to 1, which is what the Finish condition tests for. -->
    <Property Id="SBM_LAUNCH" Value="1" />

    <!-- Both are launched through explorer.exe deliberately. These actions run in the msiexec client
         process, which is elevated whenever the MSI was started from an elevated context — and a
         sidebar started from there would inherit that token and run the user's whole session as
         admin. Handing the command to the shell drops it back to the logged-in user's token.
         asyncNoWait so a browser cold-starting can't hold the Finish button hostage. -->
    <CustomAction Id="LaunchUi"
                  Directory="INSTALLFOLDER"
                  ExeCommand="explorer.exe &quot;[INSTALLFOLDER]SidebarMonitor.UI.exe&quot;"
                  Execute="immediate" Impersonate="yes" Return="asyncNoWait" />
    <CustomAction Id="ViewChangelog"
                  Directory="INSTALLFOLDER"
                  ExeCommand="explorer.exe &quot;$(ReleaseUrl)&quot;"
                  Execute="immediate" Impersonate="yes" Return="asyncNoWait" />

    <UI Id="SbmUI">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

      <!-- Every dialog WixUI_Minimal pulls in, except its ExitDialog. -->
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="WelcomeEulaDlg" />

      <Publish Dialog="WelcomeEulaDlg" Control="Install" Event="EndDialog" Value="Return" Condition="NOT Installed" />

      <Dialog Id="SbmExitDialog" Width="370" Height="270" Title="[ProductName] Setup" NoMinimize="yes">
        <Control Id="ExitBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="234" TabSkip="no"
                 Text="!(loc.WelcomeDlgBitmap)" />
        <Control Id="ExitTitle" Type="Text" X="135" Y="20" Width="220" Height="60" Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Bigger}Setup complete" />
        </Control>

        <!-- The same dialog ends an uninstall, so anything install-specific hides itself there:
             offering to start what was just removed would be nonsense.
             The test is REMOVE~="ALL" ("this run is uninstalling"), NOT `Installed` ("this product was
             already on the machine"). They differ on a REPAIR from Programas y características — which
             this MSI offers, setting neither ARPNOREPAIR nor ARPNOMODIFY — where `Installed` is true but
             nothing was removed, so `Installed` would end a successful repair by claiming the product is
             gone and hiding the launch box. -->
        <Control Id="ExitDescInstall" Type="Text" X="135" Y="80" Width="220" Height="50" Transparent="yes" NoPrefix="yes"
                 HideCondition="REMOVE~=&quot;ALL&quot;"
                 Text="SidebarMonitor is installed. The sensor helper starts automatically — nothing else to set up." />
        <Control Id="ExitDescRemove" Type="Text" X="135" Y="80" Width="220" Height="50" Transparent="yes" NoPrefix="yes"
                 HideCondition="NOT REMOVE~=&quot;ALL&quot;"
                 Text="SidebarMonitor has been removed. Your settings and layout are kept." />

        <Control Id="LaunchCheckBox" Type="CheckBox" X="135" Y="150" Width="220" Height="17"
                 HideCondition="REMOVE~=&quot;ALL&quot;"
                 Property="SBM_LAUNCH" CheckBoxValue="1" Text="Start SidebarMonitor now" />
        <Control Id="ChangelogCheckBox" Type="CheckBox" X="135" Y="170" Width="220" Height="17"
                 HideCondition="REMOVE~=&quot;ALL&quot;"
                 Property="SBM_CHANGELOG" CheckBoxValue="1" Text="See what's new in this version" />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <!-- Order matters: both actions fire before the dialog ends. -->
        <Control Id="Finish" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Cancel="yes"
                 Text="!(loc.WixUIFinish)">
          <Publish Event="DoAction" Value="ViewChangelog" Condition="SBM_CHANGELOG = 1 AND NOT REMOVE~=&quot;ALL&quot;" />
          <Publish Event="DoAction" Value="LaunchUi" Condition="SBM_LAUNCH = 1 AND NOT REMOVE~=&quot;ALL&quot;" />
          <Publish Event="EndDialog" Value="Return" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Disabled="yes"
                 Text="!(loc.WixUICancel)">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes"
                 Text="!(loc.WixUIBack)" />
      </Dialog>

      <InstallUISequence>
        <Show Dialog="SbmExitDialog" OnExit="success" />
      </InstallUISequence>
    </UI>
    <ui:WixUI Id="WixUI_Common" />

    <WixVariable Id="WixUILicenseRtf" Value="$(Stage)\license.rtf" />
    <WixVariable Id="WixUICostingPopupOptOut" Value="1" />
  </Package>

  <!-- Everything the build staged (the three apps' self-contained output + the generated launcher,
       task XML and license) installs into the program folder. -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(Stage)\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
