<?xml version="1.0" encoding="utf-8"?>
<!--
  SidebarMonitor MSI (WiX v6). Installs the three apps to Program Files, registers the elevated
  helper as a logon scheduled task, sets the UI to autostart under the user's Run key, and adds a
  Start-menu shortcut. The install path is fixed so the launcher and task XML can hardcode it.
  Build with installer/build.ps1 (which stages the self-contained publish + generated files).
-->
<?ifndef Flavor ?><?define Flavor = "full" ?><?endif?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="SidebarMonitor"
           Manufacturer="WRCX"
           Version="$(Version)"
           UpgradeCode="5B2D9E14-7C3A-4F6B-9A21-8E4D2C1F0A73"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <!-- AllowSameVersionUpgrades lets the user switch between the full and lite installers (same
         version, different bundling) without uninstalling first. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of SidebarMonitor is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Task Manager / Add-Remove Programs identity. -->
    <Icon Id="AppIcon.ico" SourceFile="$(ProjectRoot)\assets\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/WRCX/SidebarMonitor" />

    <!-- Fixed install location: no directory picker, so the launcher/task paths stay valid. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SidebarMonitor" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />

    <Feature Id="Main" Title="SidebarMonitor" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AutostartAndShortcut" />
      <ComponentRef Id="InstallInfo" />
    </Feature>

    <!-- Install metadata the in-app updater reads (per-machine, so it survives a %LOCALAPPDATA% wipe
         and is written elevated by the MSI, read unelevated by the UI): where we installed, which
         version, and which flavour (full/lite) so the updater downloads the matching MSI. -->
    <Component Id="InstallInfo" Directory="INSTALLFOLDER" Guid="C4E1B7A0-9D62-4F38-8B15-6A2E7C0D9F41">
      <RegistryValue Root="HKLM" Key="Software\SidebarMonitor" Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
      <RegistryValue Root="HKLM" Key="Software\SidebarMonitor" Name="Version" Type="string" Value="$(Version)" />
      <RegistryValue Root="HKLM" Key="Software\SidebarMonitor" Name="Flavor" Type="string" Value="$(Flavor)" />
    </Component>

    <!-- Autostart (UI under the all-users Run key) + Start-menu shortcut. HKLM, NOT HKCU: this is a
         per-machine MSI, installed by the msiexec SYSTEM service, so an HKCU Run value lands in SYSTEM's
         profile instead of the user's and the UI never autostarts. HKLM Run is written correctly by
         SYSTEM and starts the UI for every user at logon (each reads its own %LOCALAPPDATA% config). -->
    <Component Id="AutostartAndShortcut" Directory="ProgramMenuFolder" Guid="4B9D2E10-7C34-4A6E-9F81-3D5C8B2A1E90">
      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="SidebarMonitor"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]SidebarMonitor.UI.exe&quot;"
                     KeyPath="yes" />
      <Shortcut Id="StartMenuShortcut"
                Name="SidebarMonitor"
                Target="[INSTALLFOLDER]SidebarMonitor.UI.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
    </Component>

    <!-- The elevated helper runs from a logon scheduled task (Highest run level = no UAC prompt),
         created/removed with schtasks against the staged XML. Deferred + non-impersonated so it runs
         with the privileges to register a Highest-runlevel task. Paths are the fixed install dir. -->
    <CustomAction Id="CreateHelperTask"
                  Directory="INSTALLFOLDER"
                  ExeCommand="schtasks.exe /Create /TN &quot;SidebarMonitor Helper&quot; /XML &quot;C:\Program Files\SidebarMonitor\helper-task.xml&quot; /F"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="RunHelperNow"
                  Directory="INSTALLFOLDER"
                  ExeCommand="schtasks.exe /Run /TN &quot;SidebarMonitor Helper&quot;"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="DeleteHelperTask"
                  Directory="INSTALLFOLDER"
                  ExeCommand="schtasks.exe /Delete /TN &quot;SidebarMonitor Helper&quot; /F"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="CreateHelperTask" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="RunHelperNow" After="CreateHelperTask" Condition="NOT REMOVE" />
      <Custom Action="DeleteHelperTask" Before="RemoveFiles" Condition="REMOVE" />
    </InstallExecuteSequence>

    <!-- Minimal UI with the MIT license (the AMD SDK EULA is accepted in-app on first run). -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(Stage)\license.rtf" />
  </Package>

  <!-- Everything the build staged (the three apps' self-contained output + the generated launcher,
       task XML and license) installs into the program folder. -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(Stage)\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
