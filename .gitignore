bin/
obj/
.vs/
*.user
artifacts/
publish/

# Native shim build outputs (source + build.cmd are committed; run build.cmd to produce these)
native/**/*.dll
native/**/*.obj
native/**/*.lib
native/**/*.exp

# Vendored AMD SDK + VC runtime redistributables (fetch.ps1 populates these; never commit them)
native/RyzenSdk/*.sys
native/RyzenSdk/*.inf
native/RyzenSdk/*.cat

# ADLX SDK headers/source — AMD-proprietary, redistribution prohibited (fetch.ps1 pulls them on
# demand; only the compiled AdlxShim.dll ships). Keep fetch.ps1 tracked.
native/AdlxSdk/SDK/
